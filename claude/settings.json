{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git commit --amend*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog delete*)",
      "Bash(git reflog expire*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf ../*)",
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",
      "Bash(npm publish*)",
      "Bash(bun publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(cargo publish*)",
      "Bash(gem push*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp/claude",
      "/private/tmp/claude"
    ]
  },
  "enabledPlugins": {
    "ideate@gnar": true,
    "implement@gnar": true,
    "ignite@gnar": true,
    "superpowers@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "meta@gnar": true,
    "audit@gnar": true
  },
  "extraKnownMarketplaces": {
    "gnar": {
      "source": {
        "source": "github",
        "repo": "thegnarco/agent-skills"
      },
      "autoUpdate": true
    }
  },
  "forceLoginMethod": "claudeai",
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "*.jsr.io",
        "proxy.golang.org",
        "sum.golang.org",
        "rubygems.org",
        "*.brew.sh",
        "raw.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "repo.hex.pm",
        "hex.pm",
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.anthropic.com",
        "*.claude.com",
        "developer.mozilla.org",
        "nodejs.org",
        "typescriptlang.org",
        "stackoverflow.com",
        "hexdocs.pm"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.SecurityServer",
        "com.apple.securityd.systemkeychain",
        "com.apple.security.KeychainStasher",
        "com.apple.security.XPCKeychainSandboxCheck",
        "com.apple.trustd.agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "$TMPDIR",
        "/private/tmp"
      ]
    }
  },
  "effortLevel": "xhigh",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "editorMode": "vim",
  "teammateMode": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
