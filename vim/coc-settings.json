{
  "typescript": {
    "updateImportsOnFileMove": {
      "enabled": "project-relative"
    }
  },
  "languageserver": {
    "crystal": {
      "command": "crystalline",
      "args": ["--stdio"],
      "filetypes": ["crystal"],
      "rootPatterns": ["shard.yml"]
    },
    "elixirLS": {
      "command": "/opt/bin/elixir-ls/language_server.sh",
      "filetypes": ["elixir", "eelixir", "heex"]
    },
    "kotlin": {
      "command": "/opt/homebrew/bin/kotlin-language-server",
      "filetypes": ["kotlin"]
    },
    "ruby": {
      "command": "/Users/jyurek/.gem/ruby/3.3.5/bin/ruby-lsp",
      "filetypes": ["ruby", "eruby"]
    }
  }
}
